{
  "circuitKind": "common-source-amplifier",
  "title": "Common-Source NMOS Amplifier",
  "goldenReferenceId": "common-source-nmos-v1",
  "style": {
    "package": "circuitikz",
    "voltageConvention": "american voltages"
  },
  "nets": ["VDD", "GND", "vin", "vout", "drain"],
  "components": [
    {
      "id": "RD",
      "type": "resistor",
      "label": "$R_D$",
      "terminals": {
        "top": "VDD",
        "bottom": "drain"
      }
    },
    {
      "id": "M1",
      "type": "nmos",
      "label": "$M_1$",
      "terminals": {
        "D": "drain",
        "G": "vin",
        "S": "GND"
      }
    }
  ],
  "connections": [
    { "from": "VDD", "to": "RD.top" },
    { "from": "RD.bottom", "to": "M1.D" },
    { "from": "M1.D", "to": "vout" },
    { "from": "M1.G", "to": "vin" },
    { "from": "M1.S", "to": "GND" }
  ],
  "layoutHints": {
    "inputSide": "left",
    "outputSide": "right",
    "routingStyle": "orthogonal"
  }
}
